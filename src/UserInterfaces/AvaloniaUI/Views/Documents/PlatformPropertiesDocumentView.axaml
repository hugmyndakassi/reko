<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:Reko.UserInterfaces.AvaloniaUI.ViewModels.Documents"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:DataType="vm:PlatformPropertiesDocumentViewModel"
             x:Class="Reko.UserInterfaces.AvaloniaUI.Views.Documents.PlatformPropertiesDocumentView">
  <Grid RowDefinitions="auto,*">
	<Grid.Styles>
		<Style Selector="Label.banner">
			<Setter Property="VerticalContentAlignment" Value="Center" />
			<Setter Property="Background" Value="#D0D0D0" />
			<Setter Property="Foreground" Value="Black" />
			<Setter Property="FontSize" Value="18" />
			<Setter Property="FontWeight" Value="Bold" />
		</Style>
	</Grid.Styles>
	<Label Grid.Row="0"
		Classes="banner"
		Margin="0,16,0,8"
		HorizontalAlignment="Stretch">
		Base Address Finder
	</Label>
	<StackPanel Grid.Row="1">
		<Label>Custom platform</Label>
		<ComboBox
			ItemsSource="{Binding ViewModel.Platforms}"
			SelectedItem="{Binding ViewModel.SelectedPlatformDefinition}"
			Width="200">
		</ComboBox>
	</StackPanel>
  </Grid>
</UserControl>
